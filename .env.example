# Log ingestion
LOG_WATCH_DIR=<LOGS_LOCATION>
LOG_WATCH_RECURSIVE=true
WATCH_DEBOUNCE_SECONDS=1.5

# Chroma
CHROMA_PERSIST_DIR=<CHROMA_DATA_LOCATION>
CHROMA_COLLECTION=rca_logs

# Embedding provider: "ollama" or "bedrock"
EMBED_PROVIDER=ollama

# Ollama (embeddings — used when EMBED_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT_SECONDS=600
OLLAMA_EMBED_BATCH_SIZE=8

# AWS / Bedrock — used for the agent LLM (always) and embeddings (when EMBED_PROVIDER=bedrock)
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Bedrock embeddings (used when EMBED_PROVIDER=bedrock)
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_EMBED_DIMENSIONS=1024
BEDROCK_EMBED_BATCH_SIZE=16

# Agent
AGENT_NAME=OpsRCA

# Retrieval
SEARCH_DEFAULT_TOP_K=10
LIST_LOGS_MAX_IDS=1000

# Optional: comma-separated browser origins for the Vite UI (see README Web UI). Empty disables CORS.
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

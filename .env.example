# Log ingestion
LOG_WATCH_DIR=<LOGS_LOCATION>
LOG_WATCH_RECURSIVE=true
WATCH_DEBOUNCE_SECONDS=1.5

# Chroma
CHROMA_PERSIST_DIR=<CHROMA_DATA_LOCATION>
CHROMA_COLLECTION=rca_logs

# Ollama (embeddings only)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=embeddinggemma:latest
# First /api/embed after a restart may load the model into GPU/RAM (minutes on slow hosts).
OLLAMA_EMBED_TIMEOUT_SECONDS=600
# Texts per Ollama /api/embed request (1 = sequential, reduces long single-request timeouts).
OLLAMA_EMBED_BATCH_SIZE=8

# Strands + Bedrock (agent LLM)
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Agent
AGENT_NAME=OpsRCA

# Retrieval
SEARCH_DEFAULT_TOP_K=10
LIST_LOGS_MAX_IDS=1000
